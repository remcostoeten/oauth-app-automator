# GitHub OAuth Settings
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_PASSWORD=your-password-for-sudo-mode
OAUTH_APP_NAME=Your App Name
OAUTH_APP_DESCRIPTION=Optional description
OAUTH_BASE_URL=http://localhost:3000
OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback/github
OAUTH_PROD_BASE_URL=https://your-production-domain.com
OAUTH_PROD_CALLBACK_URL=https://your-production-domain.com/api/auth/callback/github

# Google OAuth Settings - Basic
GOOGLE_OAUTH_APP_NAME=Your Google App Name
GOOGLE_PROJECT_ID="your-google-cloud-project-id"

# Google OAuth Settings - Consent Screen
GOOGLE_USER_TYPE="external"
GOOGLE_USER_SUPPORT_EMAIL=""
GOOGLE_APP_HOMEPAGE_URL="http://localhost:3000"
GOOGLE_PRIVACY_POLICY_URL=""
GOOGLE_TERMS_OF_SERVICE_URL=""

# Google OAuth Settings - Developer Info
GOOGLE_DEVELOPER_CONTACT_EMAILS=""
GOOGLE_AUTHORIZED_DOMAINS=""

# Google OAuth Settings - Scopes & Test Users
GOOGLE_OAUTH_SCOPES="email,profile,openid"
GOOGLE_TEST_USERS=""

# General Settings
BROWSER_PROFILE_PATH="/path/to/browser/profile"
ENABLE_SECURE_LOGGING="false"
WRITE_ENV_FILE="true"